# Copy to .env and fill in. .env is gitignored.

# --- LLM provider for TradingAgents `propagate` (we use xAI/Grok) ---
XAI_API_KEY=
TRADINGAGENTS_LLM_PROVIDER=xai
TRADINGAGENTS_DEEP_THINK_LLM=grok-4.3
TRADINGAGENTS_QUICK_THINK_LLM=grok-4-fast-non-reasoning

# --- Bridge config (all optional; BRIDGE_* override bridge/config.py) ---
# Master kill switch. Unset/0 => dry-run, nothing is ever placed.
BRIDGE_ENABLED=0
# Robinhood agentic account number (required before any live placement).
BRIDGE_ACCOUNT_NUMBER=
# Override the default watchlist (comma-separated) for a run.
# BRIDGE_WATCHLIST=AAPL,MSFT,NVDA,JPM,XOM
# Risk / sizing knobs (defaults shown in bridge/config.py):
# BRIDGE_RISK_PER_TRADE=0.01
# BRIDGE_PER_NAME_CAP=0.18
# BRIDGE_SECTOR_CAP=0.30
# BRIDGE_MAX_DAILY_NOTIONAL=10000
# BRIDGE_MAX_POSITIONS=8
# BRIDGE_ALLOW_SHORT=1        # honoured only on a margin account
